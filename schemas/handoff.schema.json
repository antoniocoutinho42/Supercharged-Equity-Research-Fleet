{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "handoff.schema.json",
  "title": "handoff (substitui handoffs em prosa entre agentes)",
  "type": "object",
  "additionalProperties": false,
  "required": ["gate", "de", "para", "insumos", "entregaveis", "foco", "status"],
  "properties": {
    "gate": {
      "type": "string",
      "enum": ["G1", "G1_5", "G2", "G3_0", "G3", "G4", "G5", "G6", "G7", "G8"]
    },
    "de": {"type": "string", "minLength": 1},
    "para": {"type": "string", "minLength": 1},
    "insumos": {
      "type": "array",
      "items": {"type": "string"}
    },
    "entregaveis": {
      "type": "array",
      "items": {"type": "string"}
    },
    "foco": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["ABERTO", "ENTREGUE", "ACEITO", "DEVOLVIDO"]
    },
    "restricoes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "resposta": {
      "type": "string",
      "maxLength": 600
    }
  }
}
